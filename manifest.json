{
	"manifest_version": 3,
	"name": "Lumina Tab",
	"version": "1.0",
	"description": "A sleek, modern, and highly customizable New Tab override",
	"permissions": [
		"storage",
		"bookmarks"
	],
	"chrome_url_overrides": {
		"newtab": "index.html"
	},
	"icons": {
		"16": "icons/icon16.png",
		"32": "icons/icon32.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"action": {
		"default_icon": {
			"16": "icons/icon48.png",
			"32": "icons/icon48.png",
			"48": "icons/icon48.png",
			"128": "icons/icon128.png"
		},
		"default_title": "Lumina Tab"
	},
	"browser_specific_settings": {
		"gecko": {
			"id": "lumina-tab@local",
			"strict_min_version": "140.0",
			"data_collection_permissions": {
				"required": [
					"none"
				],
				"optional": []
			}
		},
		"gecko_android": {
			"strict_min_version": "142.0"
		}
	}
}
